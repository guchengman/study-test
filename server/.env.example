# 复制为 server/.env 后按需填写

# 数据库（与 README 一致）
DB_HOST=localhost
DB_PORT=3306
DB_USER=studyapp
DB_PASSWORD=
DB_NAME=study_test

# 生产环境必填，长度 ≥16（建议 ≥32）；开发环境可不设（将使用占位密钥，切勿用于生产）
JWT_SECRET=

# 生产环境建议设置 NODE_ENV=production（将强制校验 JWT_SECRET）
# NODE_ENV=production

# 反向代理后限流需要真实客户端 IP 时设为 1
# TRUST_PROXY=1

# 服务端 Gemini 代理（POST /api/ai/gemini/generate），用户未在网页填写 Key 时文本类 AI 可走此密钥
GEMINI_API_KEY=

# 百度 OCR（可选）
# BAIDU_API_KEY=
# BAIDU_SECRET_KEY=

PORT=3100
