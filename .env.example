# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=study_test

# JWT 密钥（至少 32 字符，生产环境务必修改）
# 使用 openssl rand -hex 32 生成随机值
JWT_SECRET=your_jwt_secret_replace_me

# AI API 密钥（可选，用户也可在应用设置页面中配置）
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=
# QWEN_API_KEY=
# ZHIPU_API_KEY=
# MOONSHOT_API_KEY=
# BAICHUAN_API_KEY=
# HUNYUAN_API_KEY=
# ERNIE_API_KEY=
# OPENROUTER_API_KEY=
# CUSTOM_API_ENDPOINT=
# CUSTOM_API_KEY=

# EmailJS 邮件验证码（可选，用于发送注册验证码邮件）
# EMAILJS_SERVICE_ID=
# EMAILJS_TEMPLATE_ID=
# EMAILJS_PUBLIC_KEY=
